# ============================================================
# YMLink-Q2 环境变量配置模板
# 使用方法: 复制此文件为 .env 并填入实际值
#   cp .env.example .env
# ============================================================

# -------------------- 系统配置 --------------------
SYSTEM_MODE=release                    # 运行模式: release / debug / test
SYSTEM_LOG_LEVEL=info                  # 日志级别: debug / info / warn / error
SYSTEM_MEM_LIMIT=0                     # 内存限制(MB), 0=不限制
SYSTEM_CPU_LIMIT=4                     # CPU核心数限制, 最小1
SYSTEM_ROBOT_THREAD_LIMIT=10           # Robot并发线程数, 最小1
SYSTEM_ROBOT_MESSAGE_LIMIT=100         # Robot消息缓存数, 最小100
SYSTEM_DBLOAD=true                     # 启动时是否加载数据库缓存
SYSTEM_DEBUG_QUESTS=                   # 调试请求列表(逗号分隔)

# -------------------- HTTP 服务 --------------------
HTTP_SERVER1_URL=:8080                 # 监听地址, 格式 :端口 或 IP:端口
HTTP_SERVER1_MODE=release              # Gin模式: release / debug
HTTP_SERVER1_AUTH_PASSWORD=changeme    # JWT签名密钥(建议32字符以上)
HTTP_SERVER1_AUTH_TIMEOUT=604800       # Token过期时间(秒), 默认7天
HTTP_SERVER1_HTML_PATH=./html          # 前端静态文件目录

# -------------------- MongoDB --------------------
MONGO1_URL=mongodb://localhost:27017   # MongoDB连接地址
MONGO1_DATABASE=ymlink_q2             # 数据库名
MONGO1_USERNAME=                       # 用户名(可选)
MONGO1_PASSWORD=                       # 密码(可选)

# -------------------- InfluxDB --------------------
INFLUX1_URL=http://localhost:8086      # InfluxDB HTTP地址
INFLUX1_ORG=ymlink                     # 组织名
INFLUX1_TOKEN=your-influx-token        # 访问令牌

# -------------------- FriendB (mmap文件数据库) --------------------
FRIENDB1_FILE_PATH=./data/friendb/friends.friendb   # 数据文件路径
FRIENDB1_TOTAL=1000000                               # 最大记录数

# -------------------- IP2Region --------------------
IP2REGION1_FILE_PATH=./data/ip2region/ip2region.xdb  # ip2region离线库路径

# -------------------- 底层驱动 (Drive Server) --------------------
# 驱动程序放在 ./drive-server/ 目录内
# 格式: 硬件类型#软件类型#软件版本#驱动URL1#驱动URL2,...
# 主服务会自动将 http 转为 ws 连接驱动的 WebSocket (drive_url/websocket)
# 多驱动用逗号分隔
DRIVE_MAPPING=server1#androidQQ#8.9.80#http://localhost:8098
DRIVE_TIMEOUT=30                       # 通信超时(秒), 最小10
DRIVE_MAX_CONN=50                      # 最大并发连接数, 最小10

# -------------------- Mobile 手机管理 --------------------
MOBILE_PORT=16100                      # 手机通信端口
MOBILE_USERNAME=                       # 手机认证用户名
MOBILE_PASSWORD=                       # 手机认证密码
